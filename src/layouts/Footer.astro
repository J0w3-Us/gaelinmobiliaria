---
/**
 * Footer.astro — Footer global del sitio.
 *
 * Vive en layouts/ porque es parte del chrome de la página,
 * no una feature de negocio. MainLayout lo importa directamente.
 */
import { SITE_CONFIG } from '../shared/config/site-settings';

const year = new Date().getFullYear();
const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsappNumber}?text=${SITE_CONFIG.whatsappMessage}`;
---

<footer class="bg-[#0a0a0a] border-t border-[#C9A84C]/15 py-10" role="contentinfo">
  <div class="px-6 md:px-12 lg:px-24 max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      {/* ── Brand ── */}
      <div class="flex flex-col gap-1">
        <span class="text-[#F5E6C8] text-sm font-bold tracking-[0.18em] uppercase">
          {SITE_CONFIG.siteName}
        </span>
        <span class="text-[#C9A84C] text-[0.6rem] tracking-[0.22em] uppercase font-medium">
          {SITE_CONFIG.eyebrow}
        </span>
      </div>

      {/* ── Nav links ── */}
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-6 gap-y-2">
          {[
            { label: 'Recorridos', href: '#recorridos' },
            { label: 'Lotes', href: '#lotes' },
            { label: 'Contacto', href: '#contacto' },
          ].map((link) => (
            <li>
              <a
                href={link.href}
                class="text-[#F5E6C8]/50 text-xs tracking-[0.12em] uppercase
                       hover:text-[#C9A84C] transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* ── Quick contact ── */}
      <div class="flex items-center gap-3">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-9 h-9 rounded-full
                 bg-[#25D366]/15 hover:bg-[#25D366]/25 transition-colors duration-200"
          aria-label="WhatsApp"
        >
          <svg viewBox="0 0 24 24" width="16" height="16" fill="#25D366">
            <path d="M12.031 21c-1.618 0-3.197-.417-4.582-1.205l-4.996 1.305 1.332-4.86A9.957 9.957 0 0 1 2.454 12C2.454 6.505 6.945 2 12.031 2c5.084 0 9.575 4.505 9.575 9.995 0 5.495-4.491 10.005-9.575 10.005Z"/>
          </svg>
        </a>
        <a
          href={SITE_CONFIG.phoneNumber}
          class="flex items-center justify-center w-9 h-9 rounded-full
                 bg-[#F5E6C8]/8 hover:bg-[#F5E6C8]/15 transition-colors duration-200"
          aria-label="Llamar"
        >
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none"
               stroke="#F5E6C8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </a>
      </div>
    </div>

    {/* ── Legal ── */}
    <div class="mt-8 pt-6 border-t border-[#C9A84C]/10 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[#F5E6C8]/25 text-[0.65rem] tracking-wide">
        © {year} {SITE_CONFIG.siteName}. Todos los derechos reservados.
      </p>
      <p class="text-[#F5E6C8]/20 text-[0.6rem] tracking-wide">
        Ciudad Maderas · Desarrollo Inmobiliario
      </p>
    </div>
  </div>
</footer>
