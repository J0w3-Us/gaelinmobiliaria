---
/**
 * Showcase.astro — Wraps the VideoGrid React island.
 *
 * Data lives here (server-side), not in index.astro.
 * VideoGrid only receives serializable props.
 *
 * Paths → /assets/videos/* and /assets/images/*
 * Files live in public/ → copied verbatim to dist/ → same URL in dev & prod.
 */
import { VideoGrid } from './index';
import type { VideoItem } from '../../shared/types/index.d';

const videos: VideoItem[] = [
  {
    id: 'recorrido-1',
    title: 'Recorrido General — Ciudad Maderas',
    subtitle: 'Áreas comunes y acceso principal',
    videoWebm: '/assets/videos/recorrido-1.webm',
    videoMp4:  '/assets/videos/recorrido-1.mp4',
    poster:    '/assets/images/recorrido-1-poster.avif',
    duration:  '0:24',
  },
  {
    id: 'recorrido-2',
    title: 'Vista de Amenidades',
    subtitle: 'Piscina, jardines y áreas recreativas',
    videoWebm: '/assets/videos/recorrido-2.webm',
    videoMp4:  '/assets/videos/recorrido-2.mp4',
    poster:    '/assets/images/recorrido-2-poster.avif',
    duration:  '0:24',
  },
];
---

<!--
  client:visible → VideoGrid only hydrates when the section enters the viewport.
  The video DOM is never created until the user clicks a card (handled inside VideoGrid).
-->
<VideoGrid
  client:visible
  videos={videos}
  sectionTitle="Recorridos Virtuales"
/>
