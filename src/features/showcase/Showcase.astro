---
/**
 * Showcase.astro — Galería interactiva + recorridos en video.
 *
 * Tabbed gallery: Privada · Pública · General · Amenidades
 * Videos: autoplay activado por IntersectionObserver (solo cuando son visibles
 *         y el navegador puede reproducirlos — sin flashes ni reproducciones fantasma).
 *
 * client:visible → el componente sólo hidrata cuando entra al viewport,
 * nunca bloquea LCP.
 */
import { PropertyShowcase } from './index';
---

<PropertyShowcase
  client:visible
  sectionTitle="Galería del Desarrollo"
/>
