---
/**
 * ContactSection.astro — Sección de contacto.
 *
 * - Static contact info and cards rendered by Astro (zero hydration)
 * - The ContactFab (speed-dial) is mounted globally in MainLayout
 *   and is NOT rendered again inside this section
 */
import { SITE_CONFIG } from '../../shared/config/site-settings';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsappNumber}?text=${SITE_CONFIG.whatsappMessage}`;
---

<section
  id="contacto"
  class="relative py-20 md:py-28 bg-[#0f0f0f]"
  aria-label="Contacto"
>
  {/* Top accent line */}
  <div class="absolute top-0 left-24 right-24 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/25 to-transparent" aria-hidden="true"></div>

  <div class="px-6 md:px-12 lg:px-24 max-w-6xl mx-auto">

    {/* ── Header ── */}
    <div class="mb-12 md:mb-16 max-w-xl">
      <span class="text-[#C9A84C] text-xs uppercase tracking-[0.28em] font-semibold">
        Estamos para ti
      </span>
      <h2 class="text-[#F5E6C8] text-3xl md:text-4xl lg:text-5xl font-bold mt-2 leading-tight">
        Contáctanos
      </h2>
      <p class="text-[#F5E6C8]/55 text-sm md:text-base mt-3">
        Habla directamente con un asesor de Ciudad Maderas.
        Sin intermediarios, sin demoras.
      </p>
    </div>

    {/* ── Contact cards grid ── */}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

      {/* WhatsApp card */}
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col gap-4 p-6 rounded-xl
               bg-[#1a1a1a] border border-[#C9A84C]/15
               hover:border-[#C9A84C]/40 hover:bg-[#1e1e1e]
               transition-all duration-300 active:scale-[0.99]"
        aria-label="Contactar por WhatsApp"
      >
        <div class="w-10 h-10 rounded-full bg-[#25D366]/15 flex items-center justify-center
                    group-hover:bg-[#25D366]/25 transition-colors duration-300">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="#25D366">
            <path d="M12.031 21c-1.618 0-3.197-.417-4.582-1.205l-4.996 1.305 1.332-4.86A9.957 9.957 0 0 1 2.454 12C2.454 6.505 6.945 2 12.031 2c5.084 0 9.575 4.505 9.575 9.995 0 5.495-4.491 10.005-9.575 10.005Z"/>
          </svg>
        </div>
        <div>
          <p class="text-[#F5E6C8] font-semibold text-sm">WhatsApp</p>
          <p class="text-[#F5E6C8]/45 text-xs mt-0.5">Respuesta inmediata</p>
        </div>
        <span class="text-[#25D366] text-xs font-medium mt-auto group-hover:underline">
          Enviar mensaje →
        </span>
      </a>

      {/* Llamar card */}
      <a
        href={SITE_CONFIG.phoneNumber}
        class="group flex flex-col gap-4 p-6 rounded-xl
               bg-[#1a1a1a] border border-[#C9A84C]/15
               hover:border-[#C9A84C]/40 hover:bg-[#1e1e1e]
               transition-all duration-300 active:scale-[0.99]"
        aria-label="Llamar por teléfono"
      >
        <div class="w-10 h-10 rounded-full bg-[#F5E6C8]/8 flex items-center justify-center
                    group-hover:bg-[#F5E6C8]/15 transition-colors duration-300">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
               stroke="#F5E6C8" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </div>
        <div>
          <p class="text-[#F5E6C8] font-semibold text-sm">Llamar</p>
          <p class="text-[#F5E6C8]/45 text-xs mt-0.5">Atención directa</p>
        </div>
        <span class="text-[#F5E6C8]/60 text-xs font-medium mt-auto group-hover:text-[#F5E6C8] group-hover:underline transition-colors">
          Marcar número →
        </span>
      </a>

      {/* Cotizar card — visual only, scroll handled by ContactFab */}
      <div
        class="group flex flex-col gap-4 p-6 rounded-xl
               bg-[#1a1a1a] border border-[#C9A84C]/25
               hover:border-[#C9A84C]/50 hover:bg-[#1e1e1e]
               transition-all duration-300"
      >
        <div class="w-10 h-10 rounded-full bg-[#C9A84C]/15 flex items-center justify-center
                    group-hover:bg-[#C9A84C]/25 transition-colors duration-300">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
               stroke="#C9A84C" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <div>
          <p class="text-[#F5E6C8] font-semibold text-sm">Cotizar</p>
          <p class="text-[#F5E6C8]/45 text-xs mt-0.5">Solicita tu presupuesto</p>
        </div>

        {/* Mini form */}
        <form
          class="flex flex-col gap-2 mt-auto"
          onsubmit="event.preventDefault()"
          aria-label="Formulario de cotización rápida"
        >
          <input
            type="text"
            placeholder="Tu nombre"
            class="w-full bg-[#0f0f0f] border border-[#C9A84C]/20 rounded-sm
                   px-3 py-2 text-xs text-[#F5E6C8] placeholder-[#F5E6C8]/30
                   focus:outline-none focus:border-[#C9A84C]/60 transition-colors"
            required
          />
          <input
            type="tel"
            placeholder="Teléfono o WhatsApp"
            class="w-full bg-[#0f0f0f] border border-[#C9A84C]/20 rounded-sm
                   px-3 py-2 text-xs text-[#F5E6C8] placeholder-[#F5E6C8]/30
                   focus:outline-none focus:border-[#C9A84C]/60 transition-colors"
            required
          />
          <button
            type="submit"
            class="w-full bg-[#C9A84C] text-neutral-950 text-xs font-semibold
                   py-2 rounded-sm hover:bg-[#dbb95a] transition-colors
                   active:scale-[0.98]"
          >
            Solicitar información
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
