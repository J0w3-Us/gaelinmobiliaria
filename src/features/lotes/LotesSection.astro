---
/**
 * LotesSection.astro — Catálogo de lotes disponibles.
 *
 * Pure Astro — no React hydration needed.
 * Will become a PropertyGrid when lot data is available.
 *
 * Data will come from site-settings.ts or a CMS adapter.
 */

interface Props {
  /** Optional override for the section title */
  title?: string;
}

const { title = 'Lotes Disponibles' } = Astro.props;
---

<section
  id="lotes"
  class="relative py-20 md:py-28 bg-[#1a1a1a]"
  aria-label={title}
>
  {/* ── Subtle top border accent ── */}
  <div class="absolute top-0 left-24 right-24 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/30 to-transparent" aria-hidden="true"></div>

  <div class="px-6 md:px-12 lg:px-24 max-w-7xl mx-auto">

    {/* ── Section header ── */}
    <div class="mb-12 md:mb-16">
      <span class="text-[#C9A84C] text-xs uppercase tracking-[0.28em] font-semibold">
        Ciudad Maderas
      </span>
      <h2 class="text-[#F5E6C8] text-3xl md:text-4xl lg:text-5xl font-bold mt-2 leading-tight">
        {title}
      </h2>
      <p class="text-[#F5E6C8]/55 text-sm md:text-base mt-3 max-w-lg">
        Selecciona el lote ideal para tu proyecto de vida o inversión.
        Disponibilidad actualizada — contáctanos para apartar.
      </p>
    </div>

    {/* ── Property grid placeholder ── */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {/* 6 placeholder cards — will be replaced with real PropertyCard components */}
      {Array.from({ length: 6 }).map((_, i) => (
        <div
          class="rounded-xl border border-[#C9A84C]/15 bg-[#0f0f0f]/60 p-6
                 flex flex-col gap-3 animate-pulse"
          style={`animation-delay: ${i * 80}ms`}
        >
          <div class="h-3 bg-[#F5E6C8]/8 rounded-full w-2/3"></div>
          <div class="h-2 bg-[#F5E6C8]/5 rounded-full w-1/2"></div>
          <div class="h-px bg-[#C9A84C]/10 my-1"></div>
          <div class="flex gap-2 mt-1">
            <div class="h-2 bg-[#F5E6C8]/5 rounded-full w-1/3"></div>
            <div class="h-2 bg-[#F5E6C8]/5 rounded-full w-1/4"></div>
          </div>
          <div class="mt-auto pt-4">
            <div class="h-8 bg-[#C9A84C]/10 rounded-sm w-full"></div>
          </div>
        </div>
      ))}
    </div>

    {/* ── Coming soon badge ── */}
    <div class="mt-10 flex justify-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full
                   bg-[#C9A84C]/10 border border-[#C9A84C]/25
                   text-[#C9A84C] text-xs font-medium tracking-widest uppercase">
        <span class="w-1.5 h-1.5 rounded-full bg-[#C9A84C] animate-pulse"></span>
        Catálogo en preparación
      </span>
    </div>
  </div>

  {/* ── Subtle bottom border ── */}
  <div class="absolute bottom-0 left-24 right-24 h-px bg-gradient-to-r from-transparent via-[#C9A84C]/20 to-transparent" aria-hidden="true"></div>
</section>
