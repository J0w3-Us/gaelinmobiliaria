---
/**
 * index.astro — Página principal de Ciudad Maderas.
 *
 * Responsabilidad única: montar las secciones en orden.
 * Toda la lógica y datos de cada sección viven en su feature/layout.
 *
 * Orden de secciones:
 *   Hero → QuiénesSomos → Showcase (amenidades) → Blog (videos) → Contacto
 *   LotesSection: oculta temporalmente por decisión del cliente.
 *   ContactFab (FAB global, fixed) montado al final del body.
 */
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../features/hero/Hero.astro';
import Showcase from '../features/showcase/Showcase.astro';
import LotesSection from '../features/lotes/LotesSection.astro';
import ContactSection from '../features/contact/ContactSection.astro';
import { ContactFab } from '../features/contact';
import { CompanyInfo } from '../features/about';
import { BlogSection } from '../features/blog';
import { SITE_CONFIG } from '../shared/config/site-settings';

const whatsappUrl = `https://wa.me/${SITE_CONFIG.whatsappNumber}?text=${SITE_CONFIG.whatsappMessage}`;
---

<MainLayout
  title="Gael Inmobiliaria | Ciudad Maderas – Lotes Residenciales"
  description="Vive o invierte en el mejor desarrollo de la región. Lotes residenciales en Ciudad Maderas."
>
  <Hero />

  {/* QUIÉNES SOMOS — sección de marca y video recorrido-2 */}
  <CompanyInfo client:load />

  {/* AMENIDADES — showcase del desarrollo */}
  <Showcase />

  {/* VIDEOS — BlogSection editorial con recorridos */}
  <BlogSection client:load />

  <ContactFab
    client:idle
    whatsappUrl={whatsappUrl}
    phoneNumber={SITE_CONFIG.phoneNumber}
  />
</MainLayout>

